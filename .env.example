# =============================================================================
# Postgres (profile-postgres service)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=profile_db
POSTGRES_HOST_PORT=5433

# Local app (host): localhost:${POSTGRES_HOST_PORT}
# Docker overrides DATABASE_URL to profile-postgres:5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/profile_db

# =============================================================================
# RabbitMQ (profile-rabbitmq service)
# =============================================================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST_PORT=5673
RABBITMQ_MGMT_HOST_PORT=15673

# Local app (host)
# Docker overrides RABBITMQ_URL to profile-rabbitmq:5672
RABBITMQ_URL=amqp://guest:guest@localhost:5673/

# =============================================================================
# MinIO (minio service — avatars)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=avatars
MINIO_USE_SSL=false

# =============================================================================
# JWT — must match auth (JWT_SECRET_KEY) and content (SHARED_JWT_SECRET)
# =============================================================================
JWT_SECRET_KEY=change-me-to-a-real-secret-key-min-32-chars
JWT_ALGORITHM=HS256

# =============================================================================
# Internal API — must match content (INTERNAL_SECRET) and payment callers
# =============================================================================
INTERNAL_SECRET=secret

# =============================================================================
# Analytics
# =============================================================================
ANALYTICS_BASE_URL=http://localhost:8003
ANALYTICS_TIMEOUT_SECONDS=5.0

# =============================================================================
# Application
# =============================================================================
PROFILE_SERVICE_PORT=8002
APP_ENV=development
DEBUG=true
PYTHONUNBUFFERED=1

# E2E (optional)
AUTH_E2E_BASE_URL=http://127.0.0.1:8000
PROFILE_E2E_BASE_URL=http://127.0.0.1:8002
PROFILE_E2E_INTERNAL_SECRET=secret
