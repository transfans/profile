# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/profile_db

# JWT (must match auth service)
JWT_SECRET_KEY=change-me-to-a-real-secret-key-min-32-chars
JWT_ALGORITHM=HS256

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=avatars
MINIO_USE_SSL=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5673/

# Internal
INTERNAL_SECRET=change-me-internal-secret

# Application
APP_ENV=development
DEBUG=true
